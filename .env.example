# Path to the (proprietary) words file. Required — the server panics on startup
# if this is unset or unreadable. Prompt-style format: one word per line,
# prefixed with one or more part-of-speech markers (e.g. "[noun][verb] play");
# "#" comments and blank lines are ignored.
#   Local dev: an absolute path on your machine.
#   On the VM:  /data/words.txt  (the data dir is mounted read-only at /data)
WORDS_FILE_PATH='/path/to/words.txt'

# Optional: one prompt per line. If unset/unreadable the server falls back to a
# built-in prompt bank. See data/prompts.example.txt for the format.
PROMPTS_FILE_PATH='/path/to/prompts.txt'

# Port to bind. Optional; defaults to 8081 if unset. In production the container
# sets this (see docker-compose.prod.yaml).
# PORT=8081

# Use 'release' in production to silence Gin's debug output; 'debug' locally.
GIN_MODE=debug
